{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "gRPC": {
    "ServerUrl": "http://usersmanagement:5015",
    "RetryPolicy": {
      "MaxAttempts": 3,
      "InitialBackoff": "00:00:05",
      "MaxBackoff": "00:01:00",
      "BackoffMultiplier": 3,
      "Timeout": "00:00:45"
    },
    "UserManagementService": {
      "ApiKey": "",
      "ApiKeyHeaderName": "server-api-key"
    }
  },
  "MongoDB": {
    "Host": "mongo",
    "Port": 27017,
    "Username": "mongo",
    "Password": "",
    "CredentialSource": "admin",
    "ConnectionString": "",
    "DatabaseName": "mongo",
    "OutboxCollectionName": "messages"
  },
  "Auth0": {
    "Domain": "dev-j2zk8vj12w7feoq5.us.auth0.com/",
    "Audience": "https://localhost:7228/api/Users",
    "ClientSecret": ""
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": "Debug",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
